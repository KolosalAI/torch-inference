# torch-inference API test configuration
BASE_URL=http://localhost:8000

# JWT configuration (from config.toml)
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ENABLED=true

# Test behavior
# Set to "true" to skip tests that require real model files
SKIP_MODEL_TESTS=false
# Set to "true" to auto-start the server if not running
AUTO_START_SERVER=false
# Path to the server binary (used when AUTO_START_SERVER=true)
SERVER_BINARY=./target/release/torch-inference

# Test timeouts (ms)
DEFAULT_TIMEOUT=10000
TTS_TIMEOUT=60000
DOWNLOAD_TIMEOUT=120000
